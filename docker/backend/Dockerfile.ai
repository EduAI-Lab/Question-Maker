# AI Service Container with ML Dependencies
FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Copy requirements for AI service
COPY docker/backend/requirements/ai.txt ./requirements.txt

# Install AI/ML dependencies
RUN pip install --upgrade pip && pip install -r requirements.txt

# Copy AI service code
COPY app/backend/ai_service.py ./
COPY app/backend/ai_models/ ./ai_models/

EXPOSE 8001
CMD ["uvicorn", "ai_service:app", "--host", "0.0.0.0", "--port", "8001"]
