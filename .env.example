# Copy to the repo root as `.env` (Docker Compose and local dev load this file).
# Backend: `app/backend` reads env from the project root when you use docker-compose,
# or set the same variables in your shell when running `npm run dev` locally.

# --- Core (required) ---
NODE_ENV=development
PORT=8000
DATABASE_URL=postgresql://postgres:password@postgres:5432/eduquery
# Local backend (no Docker): use host `localhost` instead of `postgres`, e.g.:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/eduquery

JWT_SECRET=change-me-in-development
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# Comma-separated browser origins allowed by CORS (no spaces after commas)
CORS_ORIGINS=http://localhost:5173

# 64-char hex (32 bytes). Required in production — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Logging & rate limiting (optional) ---
LOG_LEVEL=info
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=1000

# --- EduAI (course/topic sync, AI-assisted flows) ---
EDUAI_API_URL=https://eduai.ok.ubc.ca
EDUAI_API_KEY=
# Optional comma-separated course codes to hide from the course picker
# EDUAI_IGNORED_COURSE_CODES=courseA,courseB

# --- Direct LLM keys (optional; used when generating questions with Groq / OpenAI / DeepSeek) ---
# GROQ_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# Optional tuning (defaults exist in code)
# DEFAULT_NUM_QUESTIONS=15
# MAX_QUESTIONS=50

# --- Bug report admin (optional) ---
# Comma-separated emails that may access the bug-report triage UI in addition to the default admin user.
# BUG_REPORT_ADMIN_EMAILS=

# --- Frontend (Vite loads from repo root) ---
VITE_API_URL=http://localhost:8000

# --- Integration tests (optional; used by Jest integration suite) ---
# TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/eduquery_test

# --- Production Docker Compose only (see docker-compose.yml) ---
# POSTGRES_PASSWORD_PRODUCTION=strong-random-password

# --- Server automated deploy only (see docs/deployment/cron.md) ---
# One of these for `git pull` on private repos — never commit a real token:
# GITHUB_TOKEN=
# GITHUB_PERSONAL_ACCESS_TOKEN=
# PERSONAL_ACCESS_TOKEN=
