# ===========================================
# SHARED CONFIGURATION
# ===========================================
NODE_ENV=development
APP_NAME=EduQuery.ai
APP_VERSION=1.0.0

# ===========================================
# BACKEND CONFIGURATION
# ===========================================
# Server
PORT=8000
DATABASE_URL=postgresql://postgres:password@postgres:5432/eduquery

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AI API Keys
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# EduAI API Configuration
EDUAI_API_URL=https://eduai.ok.ubc.ca
EDUAI_API_KEY=your-eduai-api-key

# AI Settings
DEFAULT_NUM_QUESTIONS=15
MAX_QUESTIONS=50

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=EduQuery.ai
VITE_APP_VERSION=1.0.0
