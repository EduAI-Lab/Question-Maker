# ===========================================
# SHARED CONFIGURATION
# ===========================================
NODE_ENV=development
APP_NAME=QuestionMaker
APP_VERSION=1.0.0

# ===========================================
# BACKEND CONFIGURATION
# ===========================================
# Server
PORT=8000
DATABASE_URL=postgresql://postgres:password@postgres:5432/eduquery

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AI API Keys
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# EduAI API Configuration
EDUAI_API_URL=https://eduai.ok.ubc.ca
EDUAI_API_KEY=your-eduai-api-key # To be updated after getting the API key from EduAI
EDUAI_IGNORED_COURSE_CODES=Introduction to Statistics,cs,Scientific Research Methods # Stops these Edu AI courses from being shown in the question maker course list

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# AI Settings
DEFAULT_NUM_QUESTIONS=15
MAX_QUESTIONS=50

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=QuestionMaker
VITE_APP_VERSION=1.0.0

PERSONAL_ACCESS_TOKEN=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
DATABASE_URL_SERVER=postgresql://postgres:password@postgres:5432/eduquery
POSTGRES_PASSWORD_PRODUCTION=password



CANVAS_API_KEY=your-canvas-api-key

ENCRYPTION_KEY=5eb9269cfc261673627edec31392d2fb1c86d86ce17d2cce51fb09c854ae7ab9 # Used to encrypt the Canvas API key, You can generate a random key using the following command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"